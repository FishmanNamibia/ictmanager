# I-ICTMS API — copy to .env
NODE_ENV=development
PORT=3001

# PostgreSQL (multi-tenant single DB with tenant_id)
# After running scripts/create-db.sql: user root, database iictms
DATABASE_URL=postgresql://root:root@localhost:5432/iictms

# JWT (use long random string in production)
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_EXPIRES_IN=7d

# Optional: AD/LDAP (Phase 2)
# LDAP_URL=
# LDAP_BIND_DN=
# LDAP_BIND_PASSWORD=
# LDAP_SEARCH_BASE=

# Optional: Email (Phase 2)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# PDF Generation (Puppeteer)
# Override the Chrome/Chromium executable path if not in the default Windows location
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Automation Engine
# Email address shown as the reporter on auto-generated tickets and risks
# AUTOMATION_REPORTER_EMAIL=automation@i-ictms.local
# Days before contract expiry that triggers an automation alert (default: 90)
# CONTRACT_NOTICE_DAYS=90
# Days before license expiry that triggers a service desk ticket (default: 30)
# LICENSE_TICKET_WINDOW_DAYS=30
